# Dataset Generator Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys
# =============================================================================

# NewsAPI (https://newsapi.org/)
# Free tier: 100 requests/day
NEWS_API_KEY=

# GNews API (https://gnews.io/)
# Free tier: 100 requests/day
GNEWS_API_KEY=

# YouTube Data API (https://console.cloud.google.com/)
# Free tier: 10,000 units/day
YOUTUBE_API_KEY=

# Reddit API (https://www.reddit.com/prefs/apps)
# Rate limit: 60 requests/minute
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=DatasetGenerator/1.0

# Semantic Scholar API (https://www.semanticscholar.org/product/api)
# Free tier: 100 requests/5 minutes
SEMANTIC_SCHOLAR_KEY=

# =============================================================================
# Optional API Keys
# =============================================================================

# OpenAI API (for Whisper transcription)
# OPENAI_API_KEY=

# HuggingFace (for advanced models)
# HUGGINGFACE_TOKEN=

# =============================================================================
# Collection Settings
# =============================================================================

# Default language for collection
DEFAULT_LANGUAGE=pt_br

# Maximum concurrent workers
MAX_WORKERS=4

# Checkpoint interval (items per checkpoint)
CHECKPOINT_INTERVAL=100

# Request timeout in seconds
REQUEST_TIMEOUT=30

# =============================================================================
# Quality Settings
# =============================================================================

# Minimum tokens per entry
MIN_TOKENS=50

# Maximum tokens per entry
MAX_TOKENS=4096

# Minimum quality score (0-1)
MIN_QUALITY_SCORE=0.6

# Similarity threshold for deduplication (0-1)
SIMILARITY_THRESHOLD=0.85

# Language detection confidence (0-1)
LANGUAGE_CONFIDENCE=0.95

# =============================================================================
# Directory Settings
# =============================================================================

# Output directory
OUTPUT_DIR=./outputs

# Checkpoint directory
CHECKPOINT_DIR=./checkpoints

# Logs directory
LOGS_DIR=./logs
